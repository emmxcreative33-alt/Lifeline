    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; }
        :root {
            --primary: #3b82f6; --primary-dark: #2563eb; --secondary: #10b981; --accent: #f59e0b;
            --danger: #ef4444; --bg-dark: #0f172a; --bg-card: #1e293b; --bg-elevated: #334155;
            --text-primary: #f8fafc; --text-secondary: #94a3b8; --border: #475569;
            --gradient-1: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            --gradient-2: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
            --gradient-3: linear-gradient(135deg, #4facfe 0%, #00f2fe 100%);
        }
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
            background: var(--bg-dark); color: var(--text-primary); min-height: 100vh; overflow-x: hidden;
        }
        .app-container { max-width: 430px; margin: 0 auto; min-height: 100vh; position: relative; background: var(--bg-dark); }
        .header {
            padding: 20px; background: var(--bg-card); border-bottom: 1px solid var(--border);
            position: sticky; top: 0; z-index: 100; backdrop-filter: blur(10px);
        }
        .header-content { display: flex; justify-content: space-between; align-items: center; }
        .logo { display: flex; align-items: center; gap: 10px; }
        .logo-icon {
            width: 40px; height: 40px; background: var(--gradient-1); border-radius: 12px;
            display: flex; align-items: center; justify-content: center; font-size: 20px;
        }
        .logo-text {
            font-size: 24px; font-weight: 700; background: var(--gradient-1);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        }
        .header-actions { display: flex; gap: 12px; }
        .icon-btn {
            width: 40px; height: 40px; border-radius: 10px; background: var(--bg-elevated); border: none;
            color: var(--text-primary); display: flex; align-items: center; justify-content: center;
            cursor: pointer; transition: all 0.3s; font-size: 18px;
        }
        .icon-btn:hover { background: var(--primary); transform: scale(1.05); }
        .health-score-card {
            margin: 20px; padding: 24px; background: var(--bg-card); border-radius: 24px;
            border: 1px solid var(--border); position: relative; overflow: hidden;
        }
        .health-score-card::before {
            content: ''; position: absolute; top: -50%; right: -50%; width: 200%; height: 200%;
            background: radial-gradient(circle, rgba(59,130,246,0.1) 0%, transparent 70%);
            animation: pulse 4s ease-in-out infinite;
        }
        @keyframes pulse {
            0%, 100% { transform: scale(1); opacity: 0.5; }
            50% { transform: scale(1.1); opacity: 0.8; }
        }
        .score-header {
            display: flex; justify-content: space-between; align-items: center;
            margin-bottom: 20px; position: relative; z-index: 1;
        }
        .score-label { font-size: 14px; color: var(--text-secondary); text-transform: uppercase; letter-spacing: 1px; }
        .score-trend { display: flex; align-items: center; gap: 4px; color: var(--secondary); font-size: 14px; font-weight: 600; }
        .score-main { display: flex; align-items: baseline; gap: 12px; position: relative; z-index: 1; }
        .score-value {
            font-size: 72px; font-weight: 800; background: var(--gradient-1);
            -webkit-background-clip: text; -webkit-text-fill-color: transparent; line-height: 1;
        }
        .score-max { font-size: 24px; color: var(--text-secondary); font-weight: 500; }
        .score-status { margin-top: 8px; font-size: 16px; color: var(--text-secondary); position: relative; z-index: 1; }
        .quick-actions { display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin: 0 20px 20px; }
        .action-btn {
            display: flex; flex-direction: column; align-items: center; gap: 8px;
            padding: 16px 8px; background: var(--bg-card); border: 1px solid var(--border);
            border-radius: 16px; cursor: pointer; transition: all 0.3s;
        }
        .action-btn:hover { background: var(--bg-elevated); transform: translateY(-2px); border-color: var(--primary); }
        .action-icon { width: 48px; height: 48px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 24px; }
        .action-icon.log { background: rgba(59,130,246,0.2); }
        .action-icon.meds { background: rgba(16,185,129,0.2); }
        .action-icon.mood { background: rgba(245,158,11,0.2); }
        .action-icon.vitals { background: rgba(239,68,68,0.2); }
        .action-label { font-size: 12px; color: var(--text-secondary); font-weight: 500; }
        .section-header { display: flex; justify-content: space-between; align-items: center; padding: 0 20px; margin-bottom: 12px; }
        .section-title { font-size: 18px; font-weight: 700; }
