        .timeline-icon.activity { background: rgba(16,185,129,0.2); }
        .timeline-icon.nutrition { background: rgba(245,158,11,0.2); }
        .timeline-icon.symptom { background: rgba(239,68,68,0.2); }
        .timeline-content { flex: 1; }
        .timeline-title { font-weight: 600; margin-bottom: 4px; }
        .timeline-value { font-size: 20px; font-weight: 700; margin-bottom: 4px; }
        .timeline-time { font-size: 12px; color: var(--text-secondary); }
        .charts-section { padding: 0 20px; margin-top: 24px; }
